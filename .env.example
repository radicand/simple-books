NODE_ENV=development
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# SQLite file (default, fine for local dev). For production use PostgreSQL — SQLite on a
# single file/PVC can lose data on node loss, corrupt mounts, or accidental deletion.
DATABASE_URL=./data/simple-books.db
# DATABASE_URL=postgresql://simplebooks:secret@localhost:5432/simplebooks

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_DISPLAY_NAME=Single Sign-On

# S3-compatible object storage (e.g. Garage). Leave S3_ENDPOINT empty for local ./data/uploads.
S3_ENDPOINT=
S3_REGION=garage
S3_BUCKET=simple-books
S3_ACCESS_KEY=
S3_SECRET_KEY=
UPLOAD_MAX_BYTES=10485760
