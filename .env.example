NODE_ENV=development
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

DATABASE_URL=./data/simple-books.db

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_DISPLAY_NAME=Single Sign-On

# S3-compatible object storage (e.g. Garage). Leave S3_ENDPOINT empty for local ./data/uploads.
S3_ENDPOINT=
S3_REGION=garage
S3_BUCKET=simple-books
S3_ACCESS_KEY=
S3_SECRET_KEY=
UPLOAD_MAX_BYTES=10485760
