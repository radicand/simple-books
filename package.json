{
  "name": "simple-books",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:reset": "rm -rf data/simple-books.db data/simple-books.db-shm data/simple-books.db-wal && bun run db:migrate && bun run db:seed",
    "auth:secret": "bun -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"",
    "test": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.3",
    "@tanstack/react-start": "^1.168.5",
    "@tanstack/router-devtools": "^1.167.0",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "nitro": "^3.0.260429-beta",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
